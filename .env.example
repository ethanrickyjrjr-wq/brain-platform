# Root-level env example for the TypeScript Refinery (Brains).
# Copy to .env.local and fill in. Never commit .env.local.
#
# This file documents the keys consumed by refinery/config/env.mts.
# For the Python ingest side (dlt pipelines), see ingest/.env.example.


# --- Brains Supabase (primary DB, owned by this project) ---
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_KEY=xxx

# --- Supabase Auth client (Next.js app side, browser-visible) ---
# Same project as SUPABASE_URL above. Publishable key is the new
# sb_publishable_* format — anon role only, safe to ship in client bundle.
# Grab from Supabase Dashboard → Project Settings → API → "Publishable key".
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx


# --- LLM + embedding APIs ---
ANTHROPIC_API_KEY=sk-ant-xxx
FRED_API_KEY=xxx
VOYAGE_KEY=xxx

# --- Web extraction vendors ---
FIRECRAWL_API_KEY=fc-xxx
SPIDER_API_KEY=sk-xxx

# --- Census ---
CENSUS_API_KEY=xxx

# --- OpenAI (chat fallback) ---
CHAT_API_KEY=sk-proj-xxx

# --- DuckDB cross-tier Postgres ATTACH (makeDuckDBSource) ---
# Required when a pack uses refinery/sources/duckdb-source.mts to pre-join
# Tier 1 Parquet with Tier 2 Postgres. Host/user/password are required; port
# defaults to 5432, database defaults to "postgres". Format matches the
# Supabase project's direct connection (NOT the pooler).
SUPABASE_PG_HOST=db.xxx.supabase.co
SUPABASE_PG_PORT=5432
SUPABASE_PG_USER=postgres
SUPABASE_PG_PASSWORD=xxx
SUPABASE_PG_DATABASE=postgres

# --- Supabase Storage S3 (Tier 1 cold lane / DuckDB Parquet reads) ---
# Get from Supabase Dashboard → Project Settings → Storage → S3 Access Keys.
SUPABASE_S3_ENDPOINT=https://xxx.supabase.co/storage/v1/s3
SUPABASE_S3_ACCESS_KEY_ID=xxx
SUPABASE_S3_SECRET_ACCESS_KEY=xxx
REGION=us-east-1

# --- LittleBird → Notion sync (roadmap:sync writes latest-sync.md here) ---
# Create an internal integration at notion.so/my-integrations scoped to the
# SWFL Data Gulf workspace. Connect it to the target page via Share → Connections.
# If either var is missing, roadmap:sync skips the push silently (no crash).
# NOTE: GHA notion-sync-weekly.yml reads NOTION_KEY (not NOTION_API_KEY) — keep both in sync.
NOTION_API_KEY=secret_xxx
NOTION_LITTLEBIRD_PAGE_ID=3658729a64598193a737f845f9747bb1

# --- GitHub (ops ledger reads raw files from the brain-platform repo) ---
# PAT scopes required: repo (read), actions:read
GITHUB_PAT=ghp_xxx
GITHUB_REPO=ethanrickyjrjr-wq/brain-platform
GITHUB_BRANCH=main

# --- Refinery mode ---
# Set to "fixture" to run packs against refinery/__fixtures__/ data; live mode
# is the default and requires the creds above.
# REFINERY_SOURCE=fixture
