# Root-level env example for the TypeScript Refinery (Brains).
# Copy to .env.local and fill in. Never commit .env.local.
#
# This file documents the keys consumed by refinery/config/env.mts.
# For the Python ingest side (dlt pipelines), see ingest/.env.example.


# --- Brains Supabase (primary DB, owned by this project) ---
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_KEY=xxx

# --- Supabase Auth client (Next.js app side, browser-visible) ---
# Same project as SUPABASE_URL above. Publishable key is the new
# sb_publishable_* format — anon role only, safe to ship in client bundle.
# Grab from Supabase Dashboard → Project Settings → API → "Publishable key".
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# --- App runtime (Next.js site) ---
# Public base URL of the deployed site; used to build citation / provenance links.
NEXT_PUBLIC_SITE_URL=https://www.swfldatagulf.com
# Base URL the app + MCP layer fetch compiled brains from (falls back to the
# Vercel deploy URL when unset).
BRAIN_PLATFORM_URL=https://www.swfldatagulf.com
# Resend API key — transactional email for the /api/waitlist endpoint.
RESEND_API_KEY=re_xxx

# --- Google Contacts import (read-only) ---
# OAuth client for "Import from Google Contacts" (/api/email/contacts/google/*).
# Cloud Console: enable the People API, add an OAuth 2.0 Web client, and register
# the redirect URI `${NEXT_PUBLIC_SITE_URL}/api/email/contacts/google/callback`.
# Scope `contacts.readonly` is SENSITIVE — submit the consent screen for Google
# verification before serving >100 real users (test users work immediately).
# Unset → the "Import from Google" button degrades to ?google_error=not_configured.
GOOGLE_OAUTH_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=xxx

# --- LLM + embedding APIs ---
ANTHROPIC_API_KEY=sk-ant-xxx
FRED_API_KEY=xxx
VOYAGE_KEY=xxx

# --- Web extraction vendors ---
FIRECRAWL_API_KEY=fc-xxx
SPIDER_API_KEY=sk-xxx

# --- Census ---
CENSUS_API_KEY=xxx

# --- OpenAI (chat fallback) ---
CHAT_API_KEY=sk-proj-xxx

# --- DuckDB cross-tier Postgres ATTACH (makeDuckDBSource) ---
# Required when a pack uses refinery/sources/duckdb-source.mts to pre-join
# Tier 1 Parquet with Tier 2 Postgres. Host/user/password are required; port
# defaults to 5432, database defaults to "postgres". Format matches the
# Supabase project's direct connection (NOT the pooler).
SUPABASE_PG_HOST=db.xxx.supabase.co
SUPABASE_PG_PORT=5432
SUPABASE_PG_USER=postgres
SUPABASE_PG_PASSWORD=xxx
SUPABASE_PG_DATABASE=postgres

# --- Supabase Storage S3 (Tier 1 cold lane / DuckDB Parquet reads) ---
# Get from Supabase Dashboard → Project Settings → Storage → S3 Access Keys.
SUPABASE_S3_ENDPOINT=https://xxx.supabase.co/storage/v1/s3
SUPABASE_S3_ACCESS_KEY_ID=xxx
SUPABASE_S3_SECRET_ACCESS_KEY=xxx
REGION=us-east-1

# --- LittleBird → Notion sync (roadmap:sync writes latest-sync.md here) ---
# Create an internal integration at notion.so/my-integrations scoped to the
# SWFL Data Gulf workspace. Connect it to the target page via Share → Connections.
# If either var is missing, roadmap:sync skips the push silently (no crash).
# NOTE: roadmap:sync reads NOTION_API_KEY; the weekly GHA (notion-sync-weekly.yml)
# reads NOTION_KEY — set both to the same integration secret.
NOTION_API_KEY=secret_xxx
NOTION_KEY=secret_xxx
NOTION_LATEST_SYNC_PAGE=xxx
NOTION_LITTLEBIRD_PAGE_ID=xxx

# --- GitHub (ops ledger reads raw files from the brain-platform repo) ---
# PAT scopes required: repo (read), actions:read
GITHUB_PAT=ghp_xxx
GITHUB_REPO=ethanrickyjrjr-wq/brain-platform
GITHUB_BRANCH=main

# --- Refinery mode ---
# Set to "fixture" to run packs against refinery/__fixtures__/ data; live mode
# is the default and requires the creds above.
# REFINERY_SOURCE=fixture

# --- MCP Bearer Token (optional) ---
# Set to gate POST /api/mcp and DELETE /api/mcp with Bearer auth.
# Leave blank to keep the endpoint open (v1 mode).
MCP_BEARER_TOKEN=

# --- Cost guards: per-client weekly caps for the public paid-LLM streams ---
# Both are READ LIVE (tunable without redeploy). 0 / unset = disabled (no cap; the
# per-IP burst limiter in middleware + a Vercel WAF rule remain the floor either way).
HIGHLIGHTER_FREE_WEEKLY_CAP=
WELCOME_CHAT_FREE_WEEKLY_CAP=

# --- Cookie / nonce signing secret ---
# HMAC key that signs the sdg_cid cookie AND the email schedule-command confirm nonce
# (lib/email/proposal-nonce.ts). Set in prod. Unset → the confirm route falls back to
# the legacy (non-nonce) path; the per-client caps above still work via the cid cookie.
SDG_COOKIE_SECRET=

# --- Email product flags / secrets ---
# Honor per-place/topic scoping in the multi-tenant digest. Until the scoped-content
# consumer ships (Task 02), leave UNSET/false: the schedule-command confirmation then
# says the digest is region-wide "for now" instead of promising a filtered send.
SCOPE_CONSUMER_LIVE=
# Bearer the cron worker uses to POST /api/email/broadcast (also a Vercel env + GHA secret).
DIGEST_BROADCAST_SECRET=
