# Root-level env example for the TypeScript Refinery (Brains).
# Copy to .env.local and fill in. Never commit .env.local.
#
# This file documents the keys consumed by refinery/config/env.mts.
# For the Python ingest side (dlt pipelines), see ingest/.env.example.

# --- Brains Supabase (primary DB, owned by this project) ---
BRAINS_SUPABASE_URL=https://xxx.supabase.co
BRAINS_SUPABASE_SERVICE_KEY=xxx

# --- Premise Engine Supabase (transition; remove once migration done) ---
PREMISE_SUPABASE_URL=https://xxx.supabase.co
PREMISE_SUPABASE_READONLY_KEY=xxx

# --- Sanity (Intelligence Lake = lpyl3q9w) ---
SANITY_PROJECT_ID=lpyl3q9w
SANITY_DATASET=production
SANITY_READ_TOKEN=xxx
SANITY_API_VERSION=2024-01-01

# --- LLM + embedding APIs ---
ANTHROPIC_API_KEY=sk-ant-xxx
FRED_API_KEY=xxx
VOYAGE_KEY=xxx

# --- DuckDB cross-tier Postgres ATTACH (makeDuckDBSource) ---
# Required when a pack uses refinery/sources/duckdb-source.mts to pre-join
# Tier 1 Parquet with Tier 2 Postgres. Host/user/password are required; port
# defaults to 5432, database defaults to "postgres". Format matches the
# Supabase project's direct connection (NOT the pooler).
SUPABASE_PG_HOST=db.xxx.supabase.co
SUPABASE_PG_PORT=5432
SUPABASE_PG_USER=postgres
SUPABASE_PG_PASSWORD=xxx
SUPABASE_PG_DATABASE=postgres

# --- Refinery mode ---
# Set to "fixture" to run packs against refinery/__fixtures__/ data; live mode
# is the default and requires the creds above.
# REFINERY_SOURCE=fixture
