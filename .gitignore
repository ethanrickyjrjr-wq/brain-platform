# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

.vercel

# refinery (A1 lab) — raw snapshots + per-stage JSON
.refinery-cache/

# firecrawl tool cache
.firecrawl/

# session-scoped build-context intake (gated by .claude/hooks/check-build-context.mjs)
.claude/build-context.md

# Serena MCP project memories (local, re-onboarded per-environment)
.serena/

# dlt secrets and pipeline state (never commit credentials)
.dlt/secrets.toml
.dlt/.pipeline/

# Defensive glob — catches any secrets.toml anywhere in the tree
# (e.g. ingest/secrets.toml if a future dlt entry point writes outside .dlt/)
**/secrets.toml

# Python bytecode
__pycache__/
*.pyc
.pytest_cache/

# personal_vault backups — strategic insights, never commit
.private/
