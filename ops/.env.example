# /ops — environment. Set these in the Vercel project (Root Directory = ops).
# Every value is read-only telemetry access. No write scopes.

# GitHub PAT with: repo (read), actions:read. Used for workflow runs + raw files.
GITHUB_PAT=
# owner/repo — the brain-platform repo the ledger reads.
GITHUB_REPO=ethanrickyjrjr-wq/brain-platform
# Branch the ledger reads raw files from.
GITHUB_BRANCH=main

# Supabase — service key, server-side only. Reads data_lake._dlt_loads freshness.
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Single-gate basic auth: "user:password". If unset, /ops is OPEN (dev only).
OPS_BASIC_AUTH=

# Health-check targets.
MCP_URL=https://www.swfldatagulf.com/api/mcp
MAIN_SITE_URL=https://www.swfldatagulf.com
