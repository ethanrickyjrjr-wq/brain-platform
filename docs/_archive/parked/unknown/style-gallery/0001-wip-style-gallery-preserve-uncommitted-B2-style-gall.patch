+"use client";
+
+import { useEffect, useState } from "react";
+import {
+  EMAIL_CARDS,
+  PDF_CARDS,
+  WEBSITE_CARDS,
+  LANE_NATURAL_WIDTH,
+  PLACEHOLDER_CTA,
+  exampleIdFor,
+  type Lane,
+  type StyleCard,
+} from "./style-catalog";
+
+interface Props {
+  projectId: string;
+  userEmail: string | null;
+  itemsCount: number;
+  /** email/pdf slug → rendered brand-filled HTML (for srcdoc thumbnails + lightbox). */
+  previews: Record<string, string>;
+  /** Placeholder-brand teaser HTML, one per token lane. */
+  teasers: { email: string; pdf: string };
+  /** Website TemplateIds that have a live example deliverable to thumbnail. */
+  exampleIds: string[];
+  /** Focus the brand inputs above (teaser CTA). */
+  onUseYourBrand: () => void;
+}
+
+const THUMB_W = 248;
+const THUMB_H = 184;
+
+const TABS: { lane: Lane; label: string }[] = [
+  { lane: "email", label: "Email" },
+  { lane: "pdf", label: "PDF" },
+  { lane: "website", label: "Website" },
+];
+
+type LightboxState =
+  | { kind: "html"; html: string; title: string; naturalWidth: number }
+  | { kind: "src"; src: string; title: string; naturalWidth: number }
+  | null;
+
+export function StyleGallery({
+  projectId,
+  userEmail,
+  itemsCount,
+  previews,
+  teasers,
+  exampleIds,
+  onUseYourBrand,
+}: Props) {
+  const [tab, setTab] = useState<Lane>("email");
+  const [lightbox, setLightbox] = useState<LightboxState>(null);
+  const [sending, setSending] = useState<string | null>(null);
+  const [sendMsg, setSendMsg] = useState<{ id: string; text: string; ok: boolean } | null>(null);
+  const [building, setBuilding] = useState<string | null>(null);
+  const [buildErr, setBuildErr] = useState<string | null>(null);
+
+  useEffect(() => {
+    if (!lightbox) return;
+    function onKey(e: KeyboardEvent) {
+      if (e.key === "Escape") setLightbox(null);
+    }
+    window.addEventListener("keydown", onKey);
+    return () => window.removeEventListener("keydown", onKey);
+  }, [lightbox]);
+
+  async function sendEmail(card: StyleCard) {
+    setSending(card.id);
+    setSendMsg(null);
+    try {
+      const res = await fetch("/api/email/test-send", {
+        method: "POST",
+        headers: { "content-type": "application/json" },
+        body: JSON.stringify({ slug: card.id, projectId }),
+      });
+      const json = (await res.json().catch(() => ({}))) as { error?: string; to?: string };
+      if (res.ok) {
+        setSendMsg({
+          id: card.id,
+          ok: true,
+          text: `Sent to ${json.to ?? userEmail ?? "your inbox"}`,
+        });
+      } else {
+        setSendMsg({ id: card.id, ok: false, text: json.error ?? "Send failed" });
+      }
+    } catch {
+      setSendMsg({ id: card.id, ok: false, text: "Send failed" });
+    } finally {
+      setSending(null);
+    }
+  }
+
+  function openPdf(card: StyleCard) {
+    window.open(
+      `/api/projects/${projectId}/print?slug=${encodeURIComponent(card.slug!)}`,
+      "_blank",
+    );
+  }
+
+  async function buildWebsite(card: StyleCard) {
+    setBuilding(card.templateId!);
+    setBuildErr(null);
+    try {
+      const res = await fetch(`/api/projects/${projectId}/build`, {
+        method: "POST",
+        headers: { "content-type": "application/json" },
+        body: JSON.stringify({ template: card.templateId }),
+      });
+      const json = (await res.json().catch(() => ({}))) as { id?: string; error?: string };
+      if (res.ok && json.id) {
+        window.location.assign(`/p/${json.id}`);
+        return;
+      }
+      setBuildErr(json.error ?? "Build failed");
+    } catch {
+      setBuildErr("Build failed");
+    } finally {
+      setBuilding(null);
+    }
+  }
+
+  const cards = tab === "email" ? EMAIL_CARDS : tab === "pdf" ? PDF_CARDS : WEBSITE_CARDS;
+  const naturalWidth = LANE_NATURAL_WIDTH[tab];
+
+  return (
+    <section className="mt-8 rounded-xl border border-white/10 bg-[#0d1e2b]/50 p-4">
+      <h2 className="text-sm font-semibold text-white">Brand styles</h2>
+      <p className="mt-1 text-xs text-gray-500">
+        Your real data in your brand colors. Click any style to see it full-size.{" "}
+        <span className="text-gray-400">Set your colors above and save to re-skin these.</span>
+      </p>
+
+      {/* Tabs */}
+      <div className="mt-3 flex gap-1">
+        {TABS.map((t) => (
+          <button
+            key={t.lane}
+            type="button"
+            onClick={() => setTab(t.lane)}
+            className={`rounded-full px-3 py-1 text-xs font-medium transition-colors ${
+              tab === t.lane
+                ? "bg-[#00d4aa] text-[#04121b]"
+                : "border border-white/10 text-gray-400 hover:text-gray-200"
+            }`}
+          >
+            {t.label}
+          </button>
+        ))}
+      </div>
+
+      {tab === "website" && itemsCount === 0 && (
+        <p className="mt-3 text-xs text-amber-300/80">
+          File at least one item into this project to build a website deliverable.
+        </p>
+      )}
+
+      {/* Grid */}
+      <div className="mt-4 flex flex-wrap gap-4">
+        {cards.map((card) => {
+          const isWebsite = tab === "website";
+          const html = card.slug ? previews[card.slug] : undefined;
+          const hasExample = isWebsite && exampleIds.includes(card.templateId!);
+          const exampleSrc = hasExample ? `/p/${exampleIdFor(card.templateId!)}` : undefined;
+
+          return (
+            <div
+              key={card.id}
+              className="flex w-[248px] flex-col overflow-hidden rounded-lg border border-white/10 bg-[#04121b]"
+            >
+              {/* Thumbnail */}
+              <button
+                type="button"
+                onClick={() => {
+                  if (html) setLightbox({ kind: "html", html, title: card.label, naturalWidth });
+                  else if (exampleSrc)
+                    setLightbox({ kind: "src", src: exampleSrc, title: card.label, naturalWidth });
+                }}
+                disabled={!html && !exampleSrc}
+                title={!html && !exampleSrc ? "Build to preview" : "Click to enlarge"}
+                className="group relative block bg-white"
+                style={{ width: THUMB_W, height: THUMB_H }}
+              >
+                <Thumb html={html} src={exampleSrc} naturalWidth={naturalWidth} />
+                {!html && !exampleSrc && (
+                  <span className="absolute inset-0 flex items-center justify-center bg-[#0d1e2b] text-xs text-gray-500">
+                    Build to preview
+                  </span>
+                )}
+                <span className="pointer-events-none absolute inset-0 ring-0 ring-[#00d4aa]/0 transition-all group-hover:ring-2 group-hover:ring-[#00d4aa]/50" />
+              </button>
+
+              {/* Meta + action */}
+              <div className="flex flex-1 flex-col gap-2 p-3">
+                <div>
+                  <p className="text-sm font-medium text-white">{card.label}</p>
+                  <p className="text-[11px] leading-snug text-gray-500">{card.blurb}</p>
+                </div>
+                <div className="mt-auto">
+                  {tab === "email" && (
+                    <>
+                      <button
+                        type="button"
+                        disabled={sending === card.id}
+                        onClick={() => sendEmail(card)}
+                        className="rounded-full border border-[#00d4aa]/40 px-3 py-1 text-xs font-medium text-[#00d4aa] disabled:opacity-40"
+                      >
+                        {sending === card.id ? "Sending…" : "Send to me"}
+                      </button>
+                      {sendMsg?.id === card.id && (
+                        <p
+                          className={`mt-1 text-[11px] ${sendMsg.ok ? "text-[#00d4aa]" : "text-red-400"}`}
+                        >
+                          {sendMsg.text}
+                        </p>
+                      )}
+                    </>
+                  )}
+                  {tab === "pdf" && (
+                    <button
+                      type="button"
+                      onClick={() => openPdf(card)}
+                      className="rounded-full border border-[#00d4aa]/40 px-3 py-1 text-xs font-medium text-[#00d4aa]"
+                    >
+                      Open as PDF
+                    </button>
+                  )}
+                  {tab === "website" && (
+                    <>
+                      <button
+                        type="button"
