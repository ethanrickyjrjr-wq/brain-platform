diff --git a/app/api/email/test-send/route.ts b/app/api/email/test-send/route.ts
new file mode 100644
index 00000000..e14d1015
--- /dev/null
+++ b/app/api/email/test-send/route.ts
@@ -0,0 +1,62 @@
+import { cookies } from "next/headers";
+import { NextResponse, type NextRequest } from "next/server";
+import { Resend } from "resend";
+import { createClient } from "@/utils/supabase/server";
+import { resolveUserBrand } from "@/lib/email/templates/resolve-brand";
+import { buildTestSendEmail, isEmailSlug } from "@/lib/email/templates/build-test-send";
+
+export const runtime = "nodejs";
+
+/**
+ * POST /api/email/test-send  — render one email style in the caller's brand and
+ * send it to THEIR OWN inbox. Transactional (resend.emails.send), addressed only to
+ * the authenticated user's email — so it bypasses the broadcast/unsubscribe machinery
+ * (that guard lives only in /api/email/broadcast). This is the "try it / send to
+ * myself and see if it works" path; it is NOT a send-to-others surface.
+ *
+ * Body: { slug: TemplateSlug, projectId?: string }
+ */
+
+// Lazy client — `new Resend(undefined)` throws, and Next evaluates route modules at
+// build time without runtime env. Defer construction (same pattern as /api/waitlist).
+let _resend: Resend | null = null;
+function getResend(): Resend {
+  if (_resend == null) _resend = new Resend(process.env.RESEND_API_KEY);
+  return _resend;
+}
+
+export async function POST(req: NextRequest) {
+  const supabase = createClient(await cookies());
+  const {
+    data: { user },
+  } = await supabase.auth.getUser();
+  if (!user) return NextResponse.json({ error: "unauthorized" }, { status: 401 });
+  if (!user.email) return NextResponse.json({ error: "no email on your account" }, { status: 400 });
+
+  const body = (await req.json().catch(() => ({}))) as { slug?: unknown; projectId?: unknown };
+  if (!isEmailSlug(body.slug)) {
+    return NextResponse.json({ error: "invalid slug" }, { status: 400 });
+  }
+  const projectId = typeof body.projectId === "string" ? body.projectId : undefined;
+
+  // Fail loud + friendly when the key isn't present (e.g. local dev without it set),
+  // rather than a 500 from the Resend SDK.
+  if (!process.env.RESEND_API_KEY) {
+    return NextResponse.json(
+      {
+        error: "Email sending isn't configured here (RESEND_API_KEY missing in this environment).",
+      },
+      { status: 503 },
+    );
+  }
+
+  // Project brand → account default → null (falls back to SWFL palette in the builder).
+  const brand = await resolveUserBrand(supabase, user.id, projectId);
+  const email = await buildTestSendEmail({ slug: body.slug, brand, toEmail: user.email });
+
+  const result = await getResend().emails.send(email);
+  if (result.error) {
+    return NextResponse.json({ error: result.error.message ?? "send failed" }, { status: 502 });
+  }
+  return NextResponse.json({ ok: true, id: result.data?.id ?? null, to: user.email });
+}
