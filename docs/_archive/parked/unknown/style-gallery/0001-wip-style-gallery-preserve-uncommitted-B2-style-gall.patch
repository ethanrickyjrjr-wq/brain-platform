+                        title={itemsCount === 0 ? "File an item first" : undefined}
+                        onClick={() => buildWebsite(card)}
+                        className="rounded-full border border-[#00d4aa]/40 px-3 py-1 text-xs font-medium text-[#00d4aa] disabled:opacity-40"
+                      >
+                        {building === card.templateId ? "Building…" : "Build this style"}
+                      </button>
+                      {buildErr && building === null && (
+                        <p className="mt-1 text-[11px] text-red-400">{buildErr}</p>
+                      )}
+                    </>
+                  )}
+                </div>
+              </div>
+            </div>
+          );
+        })}
+
+        {/* "Create in your brand colors" teaser card */}
+        <div className="flex w-[248px] flex-col overflow-hidden rounded-lg border-2 border-dashed border-[#00d4aa]/40 bg-[#04121b]">
+          <button
+            type="button"
+            onClick={() => {
+              const t = tab === "pdf" ? teasers.pdf : teasers.email;
+              setLightbox({
+                kind: "html",
+                html: t,
+                title: PLACEHOLDER_CTA,
+                naturalWidth: LANE_NATURAL_WIDTH[tab === "pdf" ? "pdf" : "email"],
+              });
+            }}
+            className="group relative block bg-white"
+            style={{ width: THUMB_W, height: THUMB_H }}
+          >
+            <Thumb
+              html={tab === "pdf" ? teasers.pdf : teasers.email}
+              naturalWidth={LANE_NATURAL_WIDTH[tab === "pdf" ? "pdf" : "email"]}
+            />
+            <span className="pointer-events-none absolute inset-0 ring-0 transition-all group-hover:ring-2 group-hover:ring-[#00d4aa]/50" />
+          </button>
+          <div className="flex flex-1 flex-col gap-2 p-3">
+            <p className="text-sm font-medium text-white">{PLACEHOLDER_CTA}</p>
+            <p className="text-[11px] leading-snug text-gray-500">
+              This is a sample brand. Add your own colors and logo to make every style yours.
+            </p>
+            <button
+              type="button"
+              onClick={onUseYourBrand}
+              className="mt-auto rounded-full bg-[#00d4aa] px-3 py-1 text-xs font-medium text-[#04121b]"
+            >
+              Use your brand
+            </button>
+          </div>
+        </div>
+      </div>
+
+      {/* Lightbox */}
+      {lightbox && (
+        <div
+          className="fixed inset-0 z-[100] flex items-center justify-center bg-black/70 p-4 backdrop-blur-sm"
+          onClick={(e) => {
+            if (e.target === e.currentTarget) setLightbox(null);
+          }}
+        >
+          <div className="flex max-h-[88vh] w-full max-w-[960px] flex-col overflow-hidden rounded-xl border border-white/10 bg-[#0d1e2b]">
+            <div className="flex items-center justify-between border-b border-white/10 px-4 py-2">
+              <span className="text-sm font-medium text-white">{lightbox.title}</span>
+              <button
+                type="button"
+                onClick={() => setLightbox(null)}
+                className="text-gray-400 hover:text-white"
+                aria-label="Close"
+              >
+                ✕
+              </button>
+            </div>
+            <div className="overflow-auto bg-white" style={{ maxHeight: "82vh" }}>
+              {lightbox.kind === "html" ? (
+                <iframe
+                  title={lightbox.title}
+                  srcDoc={lightbox.html}
+                  sandbox=""
+                  style={{
+                    width: lightbox.naturalWidth,
+                    height: 1100,
+                    border: 0,
+                    display: "block",
+                  }}
+                />
+              ) : (
+                <iframe
+                  title={lightbox.title}
+                  src={lightbox.src}
+                  sandbox="allow-scripts allow-same-origin"
+                  style={{ width: "100%", height: "82vh", border: 0, display: "block" }}
+                />
+              )}
+            </div>
+          </div>
+        </div>
+      )}
+    </section>
+  );
+}
+
+/** A non-interactive, clipped, scaled-down render of a template for the card thumbnail. */
+function Thumb({ html, src, naturalWidth }: { html?: string; src?: string; naturalWidth: number }) {
+  if (!html && !src) return null;
+  const scale = THUMB_W / naturalWidth;
+  // Unscaled iframe height that maps exactly onto the thumbnail box after scaling.
+  const innerHeight = Math.round(THUMB_H / scale);
+  const common = {
+    width: naturalWidth,
+    height: innerHeight,
+    border: 0,
+    transform: `scale(${scale})`,
+    transformOrigin: "top left" as const,
+    pointerEvents: "none" as const,
+  };
+  return html ? (
+    <iframe title="preview" srcDoc={html} sandbox="" scrolling="no" style={common} />
+  ) : (
+    <iframe
+      title="preview"
+      src={src}
+      sandbox="allow-scripts allow-same-origin"
+      scrolling="no"
+      style={common}
+    />
+  );
+}
