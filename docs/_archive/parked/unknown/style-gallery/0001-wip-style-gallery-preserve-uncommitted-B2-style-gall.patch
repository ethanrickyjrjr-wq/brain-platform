+// Server-only: render the email/pdf template thumbnails for the style gallery.
+// Reads the real templates/html/* shells and fills them with the project's brand
+// (or SWFL defaults / the placeholder palette) so the gallery shows true output —
+// never screenshots. Imports renderHtmlTemplate (node fs); never import client-side.
+
+import { renderHtmlTemplate } from "@/lib/templates/render-html-template";
+import { SWFL_TOKEN_DEFAULTS } from "@/lib/email/templates/token-defaults";
+import { brandThemeToTokens } from "@/lib/email/templates/render-template";
+import type { BrandTheme } from "@/lib/deliverable/brand-theme";
+import {
+  SWFL_PREVIEW_LOGO_URL,
+  EXTRA_PREVIEW_TOKENS,
+  PLACEHOLDER_BRAND_TOKENS,
+} from "@/lib/email/templates/preview-brand";
+import { PREVIEW_SLUGS, TEASER_SLUG } from "./style-catalog";
+
+/** SWFL defaults + doc extras + brand overrides (PRIMARY/ACCENT/LOGO_URL when set). */
+export function buildPreviewTokens(brand: BrandTheme | null): Record<string, string> {
+  return {
+    ...SWFL_TOKEN_DEFAULTS,
+    ...EXTRA_PREVIEW_TOKENS,
+    LOGO_URL: SWFL_PREVIEW_LOGO_URL,
+    ...brandThemeToTokens(brand),
+  };
+}
+
+/** Render every email+pdf slug → { slug: html } for srcdoc thumbnails + lightbox. */
+export async function renderAllPreviews(brand: BrandTheme | null): Promise<Record<string, string>> {
+  const tokens = buildPreviewTokens(brand);
+  const entries = await Promise.all(
+    PREVIEW_SLUGS.map(async (slug) => [slug, await renderHtmlTemplate(slug, tokens)] as const),
+  );
+  return Object.fromEntries(entries);
+}
+
+/** Render the "your brand" teaser in the placeholder palette (one per token lane). */
+export async function renderTeaserPreviews(): Promise<{ email: string; pdf: string }> {
+  const tokens = { ...buildPreviewTokens(null), ...PLACEHOLDER_BRAND_TOKENS };
+  const [email, pdf] = await Promise.all([
+    renderHtmlTemplate(TEASER_SLUG.email, tokens),
+    renderHtmlTemplate(TEASER_SLUG.pdf, tokens),
+  ]);
+  return { email, pdf };
+}
