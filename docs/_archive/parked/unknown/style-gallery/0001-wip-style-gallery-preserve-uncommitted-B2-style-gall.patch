+import { describe, it, expect } from "bun:test";
+import { buildTestSendEmail, isEmailSlug } from "./build-test-send";
+
+describe("isEmailSlug", () => {
+  it("accepts the 6 known email slugs", () => {
+    for (const s of ["hero", "table", "compare", "ranked", "hbar", "report"]) {
+      expect(isEmailSlug(s)).toBe(true);
+    }
+  });
+  it("rejects doc slugs, unknown strings, and non-strings", () => {
+    expect(isEmailSlug("doc/doc-hero")).toBe(false);
+    expect(isEmailSlug("nope")).toBe(false);
+    expect(isEmailSlug(null)).toBe(false);
+    expect(isEmailSlug(42)).toBe(false);
+  });
+});
+
+describe("buildTestSendEmail", () => {
+  it("renders the chosen style in the brand primary, addressed to the caller", async () => {
+    const out = await buildTestSendEmail({
+      slug: "hero",
+      brand: { primary: "#123456", accent: "#abcdef", logoUrl: "https://cdn/x.png" },
+      toEmail: "me@example.com",
+    });
+    expect(out.to).toBe("me@example.com");
+    expect(out.from).toBe("SWFL Data Gulf <hello@swfldatagulf.com>");
+    expect(out.subject).toContain("Hero Stat");
+    expect(out.html).toContain("#123456"); // brand primary injected
+    expect(out.html).toContain("https://cdn/x.png"); // brand logo injected
+    expect(out.html).not.toContain("{{"); // no unfilled tokens
+  });
+
+  it("falls back to SWFL defaults + a default logo when brand is null (no broken img)", async () => {
+    const out = await buildTestSendEmail({
+      slug: "table",
+      brand: null,
+      toEmail: "you@example.com",
+    });
+    expect(out.html).toContain("#0F2035"); // SWFL primary default
+    expect(out.html).toContain("swfldatagulf.com/logo-transparent.svg");
+    expect(out.html).not.toContain("{{");
+  });
+});
