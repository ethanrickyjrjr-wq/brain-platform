+// Pure builder for the "send this email style to myself" test send.
+// No network / supabase / next imports — so it unit-tests without mocks. The route
+// (app/api/email/test-send) wires auth + Resend around this.
+
+import { renderEmailTemplate, brandThemeToTokens } from "./render-template";
+import { EMAIL_TEMPLATES, type TemplateSlug } from "./template-registry";
+import { SWFL_PREVIEW_LOGO_URL } from "./preview-brand";
+import type { BrandTheme } from "@/lib/deliverable/brand-theme";
+
+const EMAIL_LABELS: Record<TemplateSlug, string> = {
+  hero: "Hero Stat",
+  table: "Data Table",
+  compare: "Before / After",
+  ranked: "Ranked Top 5",
+  hbar: "Bar Chart",
+  report: "Report",
+};
+
+export function isEmailSlug(s: unknown): s is TemplateSlug {
+  return typeof s === "string" && Object.prototype.hasOwnProperty.call(EMAIL_TEMPLATES, s);
+}
+
+export interface TestSendEmail {
+  from: string;
+  to: string;
+  subject: string;
+  html: string;
+}
+
+/** Render a branded email (project brand over SWFL defaults) addressed to one user. */
+export async function buildTestSendEmail(opts: {
+  slug: TemplateSlug;
+  brand: BrandTheme | null;
+  toEmail: string;
+}): Promise<TestSendEmail> {
+  // Default the logo so a brand-less send isn't a broken <img>; brand overrides it.
+  const tokens = { LOGO_URL: SWFL_PREVIEW_LOGO_URL, ...brandThemeToTokens(opts.brand) };
+  const html = await renderEmailTemplate(opts.slug, tokens);
+  return {
+    from: "SWFL Data Gulf <hello@swfldatagulf.com>",
+    to: opts.toEmail,
+    subject: `Your "${EMAIL_LABELS[opts.slug]}" email style — SWFL Data Gulf`,
+    html,
+  };
+}
