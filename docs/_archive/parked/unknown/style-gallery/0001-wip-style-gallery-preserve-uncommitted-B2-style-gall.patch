+// Dev tool — render the style-gallery thumbnails to ONE static HTML file so you can
+// SEE the real branded templates in a browser WITHOUT running the app (which needs
+// Supabase env). Demonstrates the B2 core: real templates, re-skinned by brand tokens.
+//
+//   bun scripts/preview-style-gallery.mts   →   writes ./style-gallery-preview.html
+//
+// It is a local artifact (not wired into the app); open the printed file:// path.
+
+import { writeFileSync } from "node:fs";
+import { resolve } from "node:path";
+import { renderAllPreviews, renderTeaserPreviews } from "@/app/project/[id]/render-previews";
+import {
+  EMAIL_CARDS,
+  PDF_CARDS,
+  LANE_NATURAL_WIDTH,
+  PLACEHOLDER_CTA,
+} from "@/app/project/[id]/style-catalog";
+import type { BrandTheme } from "@/lib/deliverable/brand-theme";
+
+const THUMB_W = 300;
+const THUMB_H = 230;
+
+function thumb(html: string, naturalWidth: number, label: string): string {
+  const scale = THUMB_W / naturalWidth;
+  const innerH = Math.round(THUMB_H / scale);
+  const safe = html.replace(/"/g, "&quot;");
+  return `
+    <figure style="margin:0">
+      <div style="width:${THUMB_W}px;height:${THUMB_H}px;overflow:hidden;border:1px solid #1c3340;border-radius:8px;background:#fff">
+        <iframe srcdoc="${safe}" sandbox="" scrolling="no"
+          style="width:${naturalWidth}px;height:${innerH}px;border:0;transform:scale(${scale});transform-origin:top left"></iframe>
+      </div>
+      <figcaption style="margin-top:6px;font:13px Inter,Arial,sans-serif;color:#b8b4a8">${label}</figcaption>
+    </figure>`;
+}
+
+function laneRow(
+  previews: Record<string, string>,
+  cards: { label: string; slug?: string }[],
+  naturalWidth: number,
+): string {
+  return cards.map((c) => thumb(previews[c.slug!] ?? "", naturalWidth, c.label)).join("");
+}
+
+async function brandBlock(title: string, brand: BrandTheme | null): Promise<string> {
+  const previews = await renderAllPreviews(brand);
+  return `
+    <h2 style="font:600 18px Inter,Arial,sans-serif;color:#f0ede6;margin:32px 0 4px">${title}</h2>
+    <p style="font:13px Inter,Arial,sans-serif;color:#807e76;margin:0 0 12px">Email</p>
+    <div style="display:flex;flex-wrap:wrap;gap:18px">${laneRow(previews, EMAIL_CARDS, LANE_NATURAL_WIDTH.email)}</div>
+    <p style="font:13px Inter,Arial,sans-serif;color:#807e76;margin:18px 0 12px">PDF</p>
+    <div style="display:flex;flex-wrap:wrap;gap:18px">${laneRow(previews, PDF_CARDS, LANE_NATURAL_WIDTH.pdf)}</div>`;
+}
+
+const swfl = await brandBlock("Our brand (SWFL Data Gulf — navy / teal)", null);
+const client = await brandBlock("Sample client brand (red / gold)", {
+  primary: "#B91C1C",
+  accent: "#F59E0B",
+  logoUrl: null,
+});
+const teasers = await renderTeaserPreviews();
+const teaserBlock = `
+  <h2 style="font:600 18px Inter,Arial,sans-serif;color:#f0ede6;margin:32px 0 12px">Teaser — "${PLACEHOLDER_CTA}"</h2>
+  <div style="display:flex;flex-wrap:wrap;gap:18px">
+    ${thumb(teasers.email, LANE_NATURAL_WIDTH.email, "Email teaser")}
+    ${thumb(teasers.pdf, LANE_NATURAL_WIDTH.pdf, "PDF teaser")}
+  </div>`;
+
+const page = `<!DOCTYPE html><html><head><meta charset="utf-8"><title>Style Gallery Preview</title></head>
+<body style="margin:0;padding:28px;background:#0a1419">
+  <h1 style="font:700 24px Inter,Arial,sans-serif;color:#f0ede6;margin:0 0 4px">Brand Style Gallery — static preview</h1>
+  <p style="font:14px Inter,Arial,sans-serif;color:#807e76;margin:0">Same templates, re-skinned by brand tokens. This is what the in-app gallery renders.</p>
+  ${swfl}${client}${teaserBlock}
+</body></html>`;
+
+const out = resolve(process.cwd(), "style-gallery-preview.html");
+writeFileSync(out, page, "utf8");
+console.log(`Wrote ${out}`);
+console.log(`Open: file:///${out.replace(/\\/g, "/")}`);
