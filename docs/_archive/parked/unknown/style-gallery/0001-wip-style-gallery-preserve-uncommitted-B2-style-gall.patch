+// Shared brand/token constants for template PREVIEWS and test-sends.
+// Pure data — no fs/node imports — safe to import from server routes, the project
+// page (RSC), client code, and tests.
+
+/** Absolute logo URL — must be absolute so it resolves inside iframe `srcdoc` and
+ *  in a delivered email (relative `/logo.svg` has no base there). The transparent
+ *  teal wave mark reads cleanly on the navy default header. */
+export const SWFL_PREVIEW_LOGO_URL = "https://www.swfldatagulf.com/logo-transparent.svg";
+
+const PLACEHOLDER_LOGO_SVG =
+  `<svg xmlns="http://www.w3.org/2000/svg" width="132" height="28">` +
+  `<text x="0" y="20" font-family="Inter,Arial,sans-serif" font-size="16" font-weight="800" fill="#ffffff">YOUR LOGO</text>` +
+  `</svg>`;
+
+/** Inline data-URI wordmark for the "your brand" teaser (white, reads on any header). */
+export const PLACEHOLDER_LOGO_URL =
+  "data:image/svg+xml," + encodeURIComponent(PLACEHOLDER_LOGO_SVG);
+
+const PLACEHOLDER_MAP_SVG =
+  `<svg xmlns="http://www.w3.org/2000/svg" width="600" height="400">` +
+  `<rect width="600" height="400" fill="#e5e7eb"/>` +
+  `<text x="300" y="205" font-family="Inter,Arial,sans-serif" font-size="20" fill="#9ca3af" text-anchor="middle">Map preview</text>` +
+  `</svg>`;
+
+/** Gray placeholder for the doc-split map slot so the preview isn't blank. */
+export const PLACEHOLDER_MAP_URL = "data:image/svg+xml," + encodeURIComponent(PLACEHOLDER_MAP_SVG);
+
+/** The fake-company palette + copy for the teaser card (operator's explicit ask:
+ *  "Create one fake company ... that says 'Create In Your Brand Colors and Logo!'"). */
+export const PLACEHOLDER_BRAND_TOKENS: Record<string, string> = {
+  PRIMARY: "#7C3AED",
+  ACCENT: "#F472B6",
+  COMPANY_NAME: "Your Company",
+  TAGLINE: "Create In Your Brand Colors and Logo!",
+  LOGO_URL: PLACEHOLDER_LOGO_URL,
+};
+
+/** Tokens the doc/* templates reference beyond the email base set
+ *  (`SENDER_ADDRESS`, and `MAP_IMAGE_URL` for doc-split). */
+export const EXTRA_PREVIEW_TOKENS: Record<string, string> = {
+  SENDER_ADDRESS: "hello@swfldatagulf.com",
+  SENDER_NAME: "SWFL Data Gulf",
+  MAP_IMAGE_URL: PLACEHOLDER_MAP_URL,
+  MAP_URL: PLACEHOLDER_MAP_URL,
