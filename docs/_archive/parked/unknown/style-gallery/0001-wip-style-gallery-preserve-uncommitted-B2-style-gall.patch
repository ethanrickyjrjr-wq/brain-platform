@@ -0,0 +1,54 @@
+import { cookies } from "next/headers";
+import { NextResponse, type NextRequest } from "next/server";
+import { createClient } from "@/utils/supabase/server";
+import { renderHtmlTemplate } from "@/lib/templates/render-html-template";
+import { extractBrandTheme } from "@/lib/deliverable/brand-theme";
+import { buildPreviewTokens } from "@/app/project/[id]/render-previews";
+import { PDF_CARDS } from "@/app/project/[id]/style-catalog";
+
+export const runtime = "nodejs";
+
+/**
+ * GET /api/projects/[id]/print?slug=doc/doc-hbar  — render a PDF/doc template in the
+ * project's brand as a standalone HTML document and auto-trigger window.print(), so
+ * the browser's "Save as PDF" produces the branded doc. The doc templates already
+ * carry @media print rules. Slug is allow-listed to the known doc/* styles.
+ */
+
+const DOC_SLUGS = new Set(PDF_CARDS.map((c) => c.slug).filter((s): s is string => !!s));
+
+// Print after layout settles (web fonts / conic-gradient donut). Fires once.
+const AUTOPRINT = `<script>window.addEventListener("load",function(){setTimeout(function(){window.print();},400);});</script>`;
+
+export async function GET(req: NextRequest, { params }: { params: Promise<{ id: string }> }) {
+  const { id } = await params;
+  const supabase = createClient(await cookies());
+  const {
+    data: { user },
+  } = await supabase.auth.getUser();
+  if (!user) return NextResponse.json({ error: "unauthorized" }, { status: 401 });
+
+  const slug = req.nextUrl.searchParams.get("slug") ?? "";
+  if (!DOC_SLUGS.has(slug)) return NextResponse.json({ error: "invalid slug" }, { status: 400 });
+
+  // RLS scopes to owner — a non-owner id resolves to no row → 404.
+  const { data: project } = await supabase
+    .from("projects")
+    .select("branding")
+    .eq("id", id)
+    .maybeSingle();
+  if (!project) return NextResponse.json({ error: "not found" }, { status: 404 });
+
+  const brand = extractBrandTheme(
+    (project as { branding: Record<string, unknown> | null }).branding,
+  );
+  let html = await renderHtmlTemplate(slug, buildPreviewTokens(brand));
+  html = html.includes("</body>")
+    ? html.replace("</body>", `${AUTOPRINT}</body>`)
+    : html + AUTOPRINT;
+
+  return new NextResponse(html, {
+    status: 200,
+    headers: { "content-type": "text/html; charset=utf-8", "cache-control": "no-store" },
+  });
+}
