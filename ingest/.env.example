DESTINATION__POSTGRES__CREDENTIALS=postgresql://postgres:xxx@db.xxx.supabase.co:5432/postgres
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_KEY=xxx
CENSUS_API_KEY=xxx

# --- Extraction vendors used by Firecrawl-backed pipelines ---
# FIRECRAWL_API_KEY is the primary /v2/agent vendor (corridor_narratives,
# marketbeat_swfl, county_planning_swfl, news_swfl, lee_permits).
# SPIDER_API_KEY is the fallback for /ai/scrape — when firecrawl agent quietly
# returns data=null on dead URLs, spider returns either real rows or a structured
# HTTP error (404/525). Optional: pipelines stay on firecrawl-only if unset.
FIRECRAWL_API_KEY=fc-xxx
SPIDER_API_KEY=sk-xxx
